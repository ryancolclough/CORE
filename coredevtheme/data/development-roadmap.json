  "decisions": [
    {
      "title": "Workspace editing belongs in Settings",
      "reason": "Normal users should see role- and committee-focused work, not layout controls."
    },
    {
      "title": "Committee work prepares the meeting",
      "reason": "The Chair and Secretary should not chase reports or reconstruct work during every meeting."
    },
    {
      "title": "Standing Responsibilities differ from Action Items",
      "reason": "Recurring governance duties continue every cycle, while actions are one-time follow-ups."
    },
    {
      "title": "ORE remains the reader; CORE performs governance",
      "reason": "CORE reviews and certifies. ORE displays the official document and review dates."
    }
  ],
